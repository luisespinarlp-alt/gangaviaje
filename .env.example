# Booking.com Affiliate
BOOKING_AFFILIATE_ID=304142

# Civitatis Affiliate (opcional — sin esto usa demo)
# CIVITATIS_AFFILIATE_ID=tu_id_aqui

# TravelPayouts (opcional — sin esto usa demo de vuelos)
# Token: app.travelpayouts.com > Profile > API token
# Marker: NO es el Project ID. Genera un link de prueba en Tools > Links y resuelve
#         el short link (curl -D -) para ver el marker real en el header x-url-full
# TRS: Project ID, visible en Profile > Projects
# TRAVELPAYOUTS_TOKEN=tu_token_aqui
# TRAVELPAYOUTS_MARKER=tu_marker_real_aqui
# TRAVELPAYOUTS_TRS=tu_project_id_aqui

# Base de datos (Supabase Postgres — connection string del modo "Transaction pooler")
# DATABASE_URL=postgresql://usuario:contraseña@host:6543/postgres

# Cron (protege /api/cron contra llamadas no autorizadas)
# CRON_SECRET=genera_un_secreto_aleatorio

# Telegram (opcional — sin esto no publica en canal)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@gangaviaje

# Web
FLASK_SECRET_KEY=cambia-esto-por-algo-secreto
PORT=5002
